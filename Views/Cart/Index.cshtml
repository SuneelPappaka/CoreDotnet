@model IEnumerable<CartItem>

@{

    double total = 0;
    double itemtotal = 0;
}
<h2 class="my-4">Shopping Cart</h2>

<table class="table table-bordered shadow">
    <thead class="table-dark">
        <tr>
            <th>Image</th>
            <th>Product</th>
            <th>Description</th>
            <th style="width:120px">Quantity</th>
            <th>Unit Price</th>
            <th>Total</th>
            <th style="width:150px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var cart in Model)
        {
            itemtotal = cart.Quantit * Convert.ToDouble(cart.Product.Price);
            total += itemtotal;
            <tr>
                <td>
                    <img src="@cart.Product.ImagePath" class="img-thumbnail" style="max-height:80px" />

                </td>
                <td>
                    @cart.Product.ProductName
                </td>
                <td>
                    <small>@Html.Raw(@cart.Product.Description)</small>
                </td>
                <td class="text-center">
                    @cart.Quantit
                </td>
                <td>
                    @cart.Product.Price.ToString("0.00");
                </td>
                <td>
                    @itemtotal.ToString("0.00");
                </td>
                <td>
                    <div class="btn-group">
                        <a asp-action="plus" asp-route-cartId="@cart.Id" class="btn btn-sm btn-outline-success"><i class="bi bi-bag-plus"></i></a>
                        <a asp-action="minus" asp-route-cartId="@cart.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-dash"></i></a>
                        <a asp-action="remove" asp-route-cartId="@cart.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="table-secondary">
            <td colspan="5" class="text-end fw-bold">Grand Total</td>
            <td colspan="2" class="fm-bold">₹@total.ToString()</td>
        </tr>
    </tfoot>
</table>

<div class="text-center mt-4">
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary me-2">Continue Shopping</a>
    <a asp-controller="Summary" class="btn btn-primary">Proceed to Shopping</a>
</div>